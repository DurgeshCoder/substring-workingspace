// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String      @id @default(cuid())
  employeeCode  String      @unique
  firstName     String
  lastName      String
  email         String      @unique
  password      String
  phone         String?
  role          Role        @default(EMPLOYEE)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation   String?
  joiningDate   DateTime    @default(now())
  salary        Float?
  gender        String?
  address       String?     @db.Text
  imageUrl      String?     @db.Text
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  assignedTasks Task[]      @relation("AssignedTo")
  createdTasks  Task[]      @relation("AssignedBy")
  comments      Comment[]
  notifications Notification[]

  shiftId             String?                @map("shift_id")
  shift               Shift?                 @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  attendances         Attendance[]           @relation("EmployeeAttendance")
  approvedAttendances Attendance[]           @relation("AttendanceApprovedBy")
  corrections         AttendanceCorrection[] @relation("EmployeeCorrection")
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?     @db.Text
  priority     Priority    @default(MEDIUM)
  status       TaskStatus  @default(TODO)
  assignedById String
  assignedBy   User        @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User        @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  dueDate      DateTime?
  comments     Comment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  performedBy String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Shift {
  id           String   @id @default(cuid())
  name         String   @unique
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  graceMinutes Int      @default(15) @map("grace_minutes")
  halfDayAfter String   @map("half_day_after")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  users        User[]

  @@map("shifts")
}

model Attendance {
  id              String                 @id @default(cuid())
  employeeId      String                 @map("employee_id")
  employee        User                   @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime               @db.Date
  checkIn         DateTime?              @map("check_in")
  checkOut        DateTime?              @map("check_out")
  status          String                 @default("PRESENT")
  workingMinutes  Int                    @default(0) @map("working_minutes")
  breakMinutes    Int                    @default(0) @map("break_minutes")
  overtimeMinutes Int                    @default(0) @map("overtime_minutes")
  lateMinutes     Int                    @default(0) @map("late_minutes")
  latitude        Float?
  longitude       Float?
  address         String?                @db.Text
  ipAddress       String?                @map("ip_address")
  device          String?
  browser         String?
  approvalStatus  String                 @default("APPROVED") @map("approval_status")
  approvedById    String?                @map("approved_by")
  approvedBy      User?                  @relation("AttendanceApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?              @map("approved_at")
  remarks         String?                @db.Text
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  corrections     AttendanceCorrection[]
  logs            AttendanceLog[]

  @@unique([employeeId, date])
  @@map("attendance")
}

model AttendanceCorrection {
  id                String     @id @default(cuid())
  attendanceId      String     @map("attendance_id")
  attendance        Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employeeId        String     @map("employee_id")
  employee          User       @relation("EmployeeCorrection", fields: [employeeId], references: [id], onDelete: Cascade)
  requestedCheckIn  DateTime?  @map("requested_check_in")
  requestedCheckOut DateTime?  @map("requested_check_out")
  reason            String     @db.Text
  status            String     @default("PENDING")
  managerComment    String?    @db.Text @map("manager_comment")
  createdAt         DateTime   @default(now()) @map("created_at")
  approvedAt        DateTime?  @map("approved_at")

  @@map("attendance_corrections")
}

model Holiday {
  id        String   @id @default(cuid())
  title     String
  date      DateTime @unique @db.Date
  type      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("holidays")
}

model AttendanceLog {
  id           String     @id @default(cuid())
  attendanceId String     @map("attendance_id")
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  action       String
  performedBy  String     @map("performed_by")
  oldValue     String?    @db.Text @map("old_value")
  newValue     String?    @db.Text @map("new_value")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("attendance_logs")
}
