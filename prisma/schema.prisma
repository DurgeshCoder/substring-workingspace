// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String      @id @default(cuid())
  employeeCode  String      @unique
  firstName     String
  lastName      String
  email         String      @unique
  password      String
  phone         String?
  role          Role        @default(EMPLOYEE)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation   String?
  joiningDate   DateTime    @default(now())
  salary        Float?
  gender        String?
  address       String?     @db.Text
  imageUrl      String?     @db.Text
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  assignedTasks Task[]      @relation("AssignedTo")
  createdTasks  Task[]      @relation("AssignedBy")
  comments      Comment[]
  notifications Notification[]
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?     @db.Text
  priority     Priority    @default(MEDIUM)
  status       TaskStatus  @default(TODO)
  assignedById String
  assignedBy   User        @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User        @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  dueDate      DateTime?
  comments     Comment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  performedBy String
  metadata    Json?
  createdAt   DateTime @default(now())
}
